//QUESTION NO 25
#include<stdio.h>
int fact(int n){
    if(n==0)
    return 1;
    return n * fact(n-1);
}
int main(){
    int n;
    printf("Enter number:");
    scanf("%d",&n);
    
    printf("Factorial=%d",fact(n));
    return 0;
}


//QUESTION NO 26
#include <stdio.h>
int fib(int n){
    if(n <= 1)
        return n;
  return fib(n-1) + fib(n-2);
}

int main(){
    int n;
    printf("Enter term: ");
    scanf("%d", &n);

    printf("%d", fib(n));
    return 0;
}


//QUESTION NO 27
#include <stdio.h>
int sum(int n){
    if(n<10)
        return n;
  return(n%10)+sum(n/10);
}

int main(){
    int n;
    printf("Enter number:");
    scanf("%d", &n);

    printf("sum of digits=%d",sum(n));
    return 0;
}



//QUESTION NO 28
#include <stdio.h>
int reverse(int n,int rev){
    if(n==0)
    return rev;
    return reverse(n/10,rev*10+n%10);
}
int main(){
    int n;
    printf("Enter number:");
    scanf("%d",&n);
    
    printf("Reverse=%d",reverse(n,0));
    return 0;
}


