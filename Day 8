//QUESTION NO 31
#include<stdio.h>
int main(){
    int i,j;
    for(i=1;i<=5;i++){
        for(j=0;j<i;j++){
            printf("%c",'A'+j);
        }
        printf("\n");
    }
    return 0;
}



