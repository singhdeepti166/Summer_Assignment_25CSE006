#include<stdio.h>
int main(){
    int arr[100],n,i,sum=0;
    float avg;
    printf("Enter size:");
    scanf("%d",&n);
    printf("Enter elements:\n",n);
    for(i=0;i<n;i++){
        scanf("%d",&arr[i]);
        sum=sum+arr[i];
    }
