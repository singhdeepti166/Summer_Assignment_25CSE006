//QUESTION NO 9
#include<stdio.h>
int main(){
    int i,n,prime=1;
    printf("Enter number:");
    scanf("%d",&n);
    for(i=2;i<=n/2;i++){
        if(n%i==0){
            prime=0;
            break;
        }
    }
    if(prime==1){
        printf("Prime number");
    }
    else{
        printf("Not primr number");
    }
    return 0;
}


