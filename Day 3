#include<stdio.h>
int main(){
    int start,end,i,j,prime;
    printf("Enter start and end:");
    scanf("%d%d",&start,&end);
    
    for(i=start;i<=end;i++){
        if(i<=1)
        continue;
        prime=1;
        
        for(j=2;j<1;j++){
            if(i%j==0){
                prime=0;
                break;
            }
        }
        if(prime)
        printf("%d",i);
    }
    return 0;
}



//QUESTION NO 11
#include<stdio.h>
int main(){
    int a,b,i,j;
    printf("Enter two number:");
    scanf("%d%d",&a,&b);
  
    
    for(i=a;i>=1;i--){
        if(a%i==0){
            for(j=i;j>=1;j--){
                if(b%j==0 && i==j){
                    printf("GCD=%d",i);
                }
            }
        }
    }
    return 0; 
}



