//QUESTION NO 1
#include<stdio.h>
int main(){
    int n,sum = 0;
    printf("Enter a number:");
    scanf("%d",&n);
    for(int i=1;i<=n;i++){
        sum=sum+i;
    }
    printf("Sum of first %d natural numbers=%d",n,sum);
    return 0;
}


//QUESTION NO 2
#include<stdio.h>
int main(){
    int n;
    printf("Enter an integer:");
    scanf("%d",&n);
    for(int i=1;i<=10;i++){
        printf("%d*%d=%d\n",n,i,n*i);
    }
    return 0;
}


//QUESTION NO 3
#include<stdio.h>
int main(){
    int n,i,fact = 1;
    printf(" Enter a number:");
    scanf("%d",&n);
    for( i=1;i<=n;i++);{
        fact=fact*i;
    }
    printf("Factorial=%d",fact);
    return 0;
}


//QUESTION NO 4
#include<stdio.h>
int main(){
    int num,count=0;
    printf("Enter a number:");
    scanf("%d",&num);
    while(num !=0){
        count++;
        num=num/10;
    }
    printf("Number of digits=%d",count);
    return 0;
}

